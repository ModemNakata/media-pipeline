# ═══════════════════════════════════════════════════════════════════
# ff-s3-pipeline — Environment Configuration
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════

# ── S3 / MinIO ───────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_REGION=us-east-1
S3_BUCKET=fevid
S3_BUCKET_ORIGIN=fevid-orig

# ── API ──────────────────────────────────────────────────────────
PIPELINE_API_URL=http://app:8080
PIPELINE_API_VERIFY_SSL=true
POLL_INTERVAL=30
PIPELINE_WORK_DIR=/tmp/pipeline-work

# ── Video encoding (multi-resolution .webm) ──────────────────────
# VIDEO_PROFILES is a JSON array of profile objects.  The fields
# maxrate_kbps, bufsize_kbps, and crf are optional — omit them to let
# ffmpeg decide (no -maxrate/-bufsize/-crf flag passed).
# Example:
#   VIDEO_PROFILES=[{"name":"1080p","bandwidth":3500000,"ref_width":1920,"threshold":1080,"maxrate_kbps":9375,"bufsize_kbps":12500,"crf":30}]
VIDEO_CODEC=libsvtav1
# BY DEFAULT: grain and denoise is 0 (disabled)
# ::: SCD is enabled by default (1) so we can skip it
# keyint can also be specified in frames, e.g. 72 for 24fps
VIDEO_CODEC_PARAMS=keyint=3s:scd=1:film-grain=8:film-grain-denoise=1
VIDEO_PRESET=5
VIDEO_PIX_FMT=yuv420p10le

# ── HLS (revivable) ──────────────────────────────────────────────
# Uncomment when switching back to HLS output in transcode.py and
# manifest.py.  Used together with VIDEO_PROFILES if customised.
# HLS_SEGMENT_DURATION=4
# HLS_SEGMENT_TYPE=fmp4
# HLS_PLAYLIST_TYPE=vod
# ─────────────────────────────────────────────────────────────────

# ── Preview clips ────────────────────────────────────────────────
PREVIEW_DURATION=5

# ── AVIF (image pipeline) ────────────────────────────────────────
# CRF 0=lossless, 18-25=good, 30-35=medium, 40+=poor.
# Leave empty or comment out to use ffmpeg's default CRF (no -crf flag).
AVIF_CRF=25
AVIF_MAX_DIMENSION=0

# ── Blur (paywalled gallery images) ──────────────────────────────
BLUR_SIGMA=20.0
BLUR_STEPS=3

# ── Watermark ────────────────────────────────────────────────────
WATERMARK_ENABLED=false
WATERMARK_TEXT=fevid.cloud/
WATERMARK_FONT=
WATERMARK_COLOR=#7ccf00
WATERMARK_X=5
WATERMARK_Y=5
WATERMARK_BORDERCOLOR=black
WATERMARK_BORDERW=1
WATERMARK_FONT_RATIO=0.02

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
STREAM_CMD_OUTPUT=false
